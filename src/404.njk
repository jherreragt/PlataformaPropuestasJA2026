     <!-- propuestas -->
    <div class="section m-0">
        <div class="container py-6">
            <div class="row">
                <div class="col-lg-12">

                    <div style="text-align:center">
                        <h3>Propuestas Ciudadanas</h3>
                        <p>Te invitamos a filtrar y encontrar propuestas
                            ciudadanas en las siguientes áreas
                        </p>
                    </div>

                </div>

                <div class="col-lg-12"> 
                    <!--coleccion de filtros-->
                    {% for categoria in collections.categorias %}
                    <a href="{{categoria.url}}" class="filtros">{{categoria.data.title}}</a>
                    {% endfor %}
                    <!--button class="filtros">Cultura y deportes</button>
                    <button class="filtros">medio ambiente y recursos naturales</button>
                    <button class="filtros">salud</button>
                    <button class="filtros">transporte público</button>
                    <button class="filtros">seguridad y justicia</button>
                    <button class="filtros">derechos sexuales y reproductivos</button>
                    <button class="filtros">administración pública</button>
                    <button class="filtros">economía y trabajo</button>
                    <button class="filtros">infraestructura</button>
                    <button class="filtros">seguridad alimenticia y nutricional</button-->
                </div>

                {% for prop in collections.propuesta %}
                    {% if prop.data.producto_encuentro == "Si" %}

                    <div class="col-lg-4 my-4">
                        <div class="cuadro_propuesta">
                            <div class="tags">
                                <a class="filtros">{{prop.data.categoria}}</a>
                            </div>
                            <div class="numero_propuesta">
                                <p>propuesta N.393</p>
                            </div>
                            <div class="contenido">
                                <h5>{{prop.data.title}}</h5>
                                <p>{{prop.data.resumen}}</p>
                            </div>
                            <div class="bottom">
                                <div class="candidaturas">
                                    <h4>4</h4>
                                    <span>candidatura(s) comprometida(s)</span>
                                </div>
                                <div class="ciudadanos">
                                    <h4>20</h4>
                                    <span>apoyo(s) ciudadano(s)</span>
                                </div>
                                <div class="botones_finales">
                                    <a href="#" class="apoyar"><i class="fa-solid fa-heart" style="margin-right:4px"></i>Apoyar</a>
                                    <a href="{{prop.url}}" class="vermas">Leer más</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    {% endif %}

                    {% if prop.data.producto_encuentro == "No" %}

                    <div class="col-lg-4 my-4">
                        <div class="cuadro_propuesta">
                            <div class="tags">
                                <a class="filtros">{{prop.data.categoria}}</a>
                            </div>
                            <div class="numero_propuesta">
